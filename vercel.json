{
  "version": 2,
  "name": "ssps-engine",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ssps-engine-api.onrender.com/api/:path*"
    },
    {
      "source": "/data/:path*",
      "destination": "/frontend/data/:path*"
    },
    {
      "source": "/js/:path*",
      "destination": "/frontend/js/:path*"
    },
    {
      "source": "/css/:path*",
      "destination": "/frontend/css/:path*"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    }
  ]
}
